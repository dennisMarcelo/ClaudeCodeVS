<UserControl x:Class="ClaudeCodeVS.UI.ChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Claude Code for Visual Studio" FontSize="16" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1" Margin="0,8,0,0" TextWrapping="Wrap"
                   Text="This panel hosts the local MCP IDE server that the Claude Code CLI connects to." />

        <Border Grid.Row="2" Margin="0,16,0,0" Padding="12"
                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.PanelBorderKey}}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Server status" />
                <TextBlock Name="StatusText" Margin="0,6,0,0" Text="Starting..." />
                <TextBlock Name="PortText" Margin="0,2,0,0" Opacity="0.8" Text="Port: -" />
                <TextBlock Name="ClientsText" Margin="0,2,0,0" Opacity="0.8" Text="Connected sessions: 0" />
                <TextBlock Name="LockFileText" Margin="0,2,0,0" Opacity="0.8" TextWrapping="Wrap"
                           Text="Lock file: (not written yet)" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Name="StartTerminalButton" Content="Start Claude in terminal" Padding="10,4" Click="OnStartTerminal" />
            <Button Name="CopyEnvButton" Content="Copy env-var setup" Padding="10,4" Margin="8,0,0,0" Click="OnCopyEnv" />
        </StackPanel>

        <ScrollViewer Grid.Row="4" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="How to use" />
                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0">
                    1. Click <Bold>Start Claude in terminal</Bold> — opens a terminal with the CLI already
                    connected to this IDE.<LineBreak />
                    2. Or, from any external terminal, run <Bold>claude</Bold>. If this extension is active
                    the CLI discovers it automatically via the lock file. You can also force it with
                    <Bold>claude /ide</Bold>.<LineBreak />
                    3. Select code in the editor and press <Bold>Ctrl+Alt+K</Bold> to send it as
                    <Bold>@-mention</Bold> context to Claude.<LineBreak />
                    4. When Claude proposes an edit, Visual Studio opens a diff view. Use
                    <Bold>Ctrl+Alt+Y</Bold> to accept or <Bold>Ctrl+Alt+N</Bold> to reject.
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <TextBlock Grid.Row="5" Margin="0,12,0,0" Opacity="0.6" FontSize="11"
                   Text="Claude Code speaks MCP 2024-11-05 over WebSocket on 127.0.0.1." />
    </Grid>
</UserControl>
